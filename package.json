{
  "name": "routewrangler",
  "version": "0.0.0",
  "private": true,
  "description": "Source-agnostic Meter Data Management (MDM) system — contract water-meter reading office side.",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @routewrangler/api db:generate",
    "db:migrate": "pnpm --filter @routewrangler/api db:migrate",
    "db:check": "pnpm --filter @routewrangler/api db:check",
    "seed": "pnpm --filter @routewrangler/api seed",
    "dev": "pnpm --filter @routewrangler/api dev",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
