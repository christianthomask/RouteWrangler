# ─────────────────────────────────────────────────────────────────────────────
# RouteWrangler — environment template. Copy to `.env` for local dev.
# Auth and object storage are provider-selectable (ADR-015): the app targets AWS,
# Azure, or a local stack by config, not code. The defaults below run the whole
# system locally with zero cloud signup (docker Postgres + MinIO + dev auth).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ── Database (docker-compose Postgres for local; any Postgres in prod) ──────
DATABASE_URL=postgres://routewrangler:routewrangler@localhost:5432/routewrangler

# ── Auth provider (OIDC): cognito | entra | oidc ────────────────────────────
AUTH_PROVIDER=cognito
AWS_REGION=us-west-2
# cognito: derive issuer/jwks from region + pool id (or set explicit overrides)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=
COGNITO_JWKS_URI=
# entra (Azure): tenant + client id → issuer/jwks derived automatically
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# generic oidc: set these explicitly for any other IdP
OIDC_ISSUER=
OIDC_JWKS_URI=
OIDC_AUDIENCE=
OIDC_GROUPS_CLAIM=
# Clerk (chosen IdP — uses the generic `oidc` provider). Set AUTH_PROVIDER=oidc
# and point at your Clerk instance issuer (JWKS is issuer + /.well-known/jwks.json):
#   AUTH_PROVIDER=oidc
#   OIDC_ISSUER=https://<your-subdomain>.clerk.accounts.dev   # or your prod domain
#   OIDC_JWKS_URI=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
#   OIDC_AUDIENCE=<your api audience, if configured in the Clerk JWT template>
#   OIDC_GROUPS_CLAIM=<claim carrying role/org-role, per your Clerk JWT template>

# ── Local-only auth shim (ADR-012) ──────────────────────────────────────────
# When true AND NODE_ENV != production, the API trusts an `x-dev-user-sub`
# header instead of a JWT, so the simulator/web work without an IdP. Set true
# for local end-to-end runs. HARD-DISABLED in production.
AUTH_DEV_BYPASS=true

# ── Object storage: s3 (AWS S3 or any S3-compatible incl. MinIO) | azure_blob ─
STORAGE_PROVIDER=s3
# Local MinIO defaults (matches docker-compose). For AWS S3, drop S3_ENDPOINT/
# creds and use the instance role; set S3_BUCKET + AWS_REGION.
S3_BUCKET=routewrangler-photos
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Cloudflare R2 (chosen prod storage — uses the S3 adapter, zero code change).
# Create an R2 bucket + an R2 API token, then:
#   STORAGE_PROVIDER=s3
#   S3_BUCKET=<r2-bucket-name>
#   S3_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_FORCE_PATH_STYLE=true
#   S3_ACCESS_KEY_ID=<r2-access-key-id>
#   S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
#   AWS_REGION=auto
# Azure Blob (when STORAGE_PROVIDER=azure_blob):
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_ACCOUNT_KEY=

# ── AWS credentials for the seed's Cognito AdminCreateUser (cognito full mode) ─
# Leave blank to run the seed in local-only mode (Postgres rows, no pool users).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
