# ─────────────────────────────────────────────────────────────────────────────
# RouteWrangler — environment template. Copy to `.env` for local dev.
# Local dev is one command (`pnpm db:up && pnpm seed && pnpm dev`) EXCEPT auth,
# which talks to a real dev Cognito user pool (no local emulator exists — see
# README quick start and docs/decisions/ADR-004).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ── Database (docker-compose Postgres for local) ────────────────────────────
DATABASE_URL=postgres://routewrangler:routewrangler@localhost:5432/routewrangler

# ── Cognito (dev pool) ──────────────────────────────────────────────────────
# These are provisioned in Sprint 0 (see docs/runbook.md). Until then the API
# runs, but any authenticated endpoint returns 401. AWS_REGION drives the JWKS
# and issuer URLs when COGNITO_ISSUER / COGNITO_JWKS_URI are not set explicitly.
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# Optional explicit overrides (otherwise derived from region + pool id):
COGNITO_ISSUER=
COGNITO_JWKS_URI=

# ── AWS credentials for the seed's AdminCreateUser calls (local only) ───────
# Leave blank to run the seed in local-only mode (Postgres rows, no pool users).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 (photos, export files) ───────────────────────────────────────────────
# Until set, POST /photos/presign returns a labeled 503 (see docs/runbook.md).
S3_BUCKET=

# ── Local-only auth shim (ADR-012) ──────────────────────────────────────────
# When true AND NODE_ENV != production, the API trusts an `x-dev-user-sub`
# header instead of a Cognito JWT, so the simulator/web work without a pool.
# HARD-DISABLED in production. Leave false unless doing local end-to-end runs.
AUTH_DEV_BYPASS=false
